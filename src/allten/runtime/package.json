{
	"name": "all-ten",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"prepare": "husky install",
		"check": "run-p -cls --aggregate-output pretty-check lint ts-check test",
		"pretty": "echo 'Removed. Please use pretty-all instead.'",
		"pretty-all": "prettier \"{assets,src,test,tools}/**/*.{js,jsx,ts,tsx,css,json}\" --write",
		"pretty-check": "prettier \"{assets,src,test,tools}/**/*.{js,jsx,ts,tsx,css,json}\" --check",
		"lint": "eslint --cache \"{src,test,tools}/**/*.{js,jsx,ts,tsx}\"",
		"ts": "tsc",
		"ts-check": "tsc",
		"test": "jest",
		"build": "webpack",
		"watch": "webpack -w",
		"clear-cache": "rm .cache/*",
		"rebuild": "npm run clear-cache && npm run build",
		"rewatch": "npm run clear-cache && npm run watch",
		"build-prod": "NODE_ENV=production webpack",
		"storybook": "start-storybook -p 6006",
		"build-storybook": "build-storybook",
		"make-solutions": "python tools/makeSolutionsJSON.py",
		"make-solutions-file": "rm -f src/util/ProblemSolutions.json; python tools/makeSolutionsJSON.py > src/util/ProblemSolutions.json"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,css,json}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@stitches/react": "^1.2.8",
		"fast-printf": "^1.6.9",
		"file-loader": "^6.2.0",
		"ismobilejs": "^1.1.1",
		"lodash": "^4.17.21",
		"mobx": "^6.3.13",
		"mobx-react-lite": "^3.2.3",
		"preact": "^10.7.2",
		"pulltorefreshjs": "^0.1.22",
		"query-string": "^7.1.1",
		"react": "^17.0.2",
		"react-dom": "^17.0.2"
	},
	"devDependencies": {
		"@babel/core": "^7.17.2",
		"@babel/preset-env": "^7.16.11",
		"@babel/preset-react": "^7.16.7",
		"@babel/preset-typescript": "^7.16.7",
		"@babel/register": "^7.17.0",
		"@storybook/addon-actions": "^6.4.18",
		"@storybook/addon-essentials": "^6.4.18",
		"@storybook/addon-links": "^6.4.18",
		"@storybook/addon-storyshots": "^6.4.18",
		"@storybook/builder-webpack5": "^6.4.18",
		"@storybook/manager-webpack5": "^6.4.18",
		"@storybook/react": "^6.4.18",
		"@testing-library/jest-dom": "^5.16.2",
		"@testing-library/react": "^12.1.2",
		"@types/bluebird": "^3.5.36",
		"@types/js-yaml": "^4.0.5",
		"@types/lodash": "^4.14.178",
		"@types/mkdirp": "^1.0.2",
		"@types/pulltorefreshjs": "^0.1.5",
		"@types/react": "^17.0.39",
		"@types/react-dom": "^17.0.11",
		"@typescript-eslint/eslint-plugin": "^5.33.1",
		"@typescript-eslint/parser": "^5.33.1",
		"babel-jest": "^27.5.1",
		"babel-loader": "^8.2.3",
		"bluebird": "^3.7.2",
		"chokidar": "^3.5.3",
		"color": "^4.2.1",
		"core-js": "^3.21.0",
		"eslint": "^8.9.0",
		"husky": "^7.0.4",
		"jest": "^27.5.1",
		"jest-stitches": "^1.0.4",
		"js-yaml": "^4.1.0",
		"js-yaml-loader": "^1.2.2",
		"lint-staged": "^12.3.3",
		"mkdirp": "^1.0.4",
		"npm-run-all": "^4.1.5",
		"prettier": "^2.5.1",
		"react-test-renderer": "^17.0.2",
		"ts-node": "^10.5.0",
		"typescript": "^4.5.5",
		"webpack": "^5.68.0",
		"webpack-cli": "^4.9.2",
		"yargs": "^17.3.1"
	},
	"babel": {
		"presets": [
			"@babel/preset-typescript",
			"@babel/preset-react",
			[
				"@babel/preset-env",
				{
					"targets": {
						"node": "16"
					}
				}
			]
		]
	},
	"overrides": {
		"acorn": "8.16.0"
	}
}
