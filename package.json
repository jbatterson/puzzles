{
  "name": "puzzles",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:allten": "npm --prefix all-ten-main run build",
    "predev": "npm run build:allten && node tools/copyAllTenBundle.mjs",
