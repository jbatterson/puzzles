{
  "name": "puzzles",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "check:allten-boundary": "node tools/checkAllTenBoundary.mjs",
    "check:header-parity": "node tools/checkHeaderParity.mjs",
    "check:clueless-ambiguity": "node tools/clueless/checkCluelessAmbiguity.mjs",
    "check:clueless-ambiguity-jsonl": "python tools/clueless/checkCluelessAmbiguityJsonl.py",
    "strip:clueless-ambiguous": "python tools/clueless/checkCluelessAmbiguityJsonl.py -i tools/reports/clueless-combined-pruned.jsonl --vocab tools/reports/wordle-answers-zipf.csv --output-clean tools/reports/clueless-combined-pruned-unambiguous.jsonl",
    "sort:clueless-minzipf": "python tools/clueless/sortCluelessPuzzlesByMinZipf.py",
    "wordle:zipf-report": "python tools/clueless/wordleAnswersZipfReport.py",
    "generate:clueless-puzzles": "python tools/clueless/generateCluelessPuzzles.py",
    "build:clueless-pool": "python tools/clueless/buildCandidatePool.py",
    "select:clueless-puzzles": "python tools/clueless/selectCluelessPuzzles.py",
    "build:clueless-js": "python tools/clueless/buildCluelessPuzzlesJsFromJsonl.py",
    "filter:clueless-js": "python tools/clueless/filterCluelessPuzzlesJs.py",
    "report:clueless-combined": "python tools/clueless/cluelessCombinedReport.py",
    "dedupe:clueless-combined": "python tools/clueless/cluelessCombinedReport.py --dedupe-only",
    "stats:clueless-combined": "python tools/clueless/cluelessCombinedReport.py --stats-from-combined",
    "prune:clueless-overlap": "python tools/clueless/cluelessPruneOverlap.py",
    "check:migration": "npm run check:allten-boundary && npm run check:header-parity && npm --prefix src/allten/runtime run test -- AppState.test.ts && npm run build",
    "predev": "npm run check:allten-boundary",
    "dev": "vite",
    "prebuild": "npm run check:allten-boundary",
    "build": "vite build",
    "deploy": "npm run build && gh-pages -d dist --dotfiles",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@stitches/react": "^1.2.8",
    "copy-to-clipboard": "^3.3.3",
    "fast-printf": "^1.6.9",
    "ismobilejs": "^1.1.1",
    "lodash": "^4.17.21",
    "mobx": "^6.3.13",
    "mobx-react-lite": "^4.1.1",
    "pulltorefreshjs": "^0.1.22",
    "query-string": "^7.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "vite": "^7.3.1"
  }
}
